# LYSHLbot Environment Configuration

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

ONEBOT_PROTOCOL=v11
ONEBOT_ACCESS_TOKEN=
ONEBOT_NAPCAT_WS=ws://127.0.0.1:3001

LOG_LEVEL=info
LOG_FILE=./logs/app.log

ENABLE_CORS=true
CORS_ORIGINS=*

PLUGIN_DIR=./plugins
PLUGIN_AUTO_LOAD=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

SECURITY_API_KEY=

WS_REVERSE_PATH=/ws/reverse
WS_HEARTBEAT_INTERVAL=15000
